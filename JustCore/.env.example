# JustCore — variáveis de ambiente (copie para .env e preencha)

# Banco PostgreSQL (Prisma). Em produção/dev use o Neon (free tier persistente).
# Use a connection string POOLED do Neon (host com "-pooler") + sslmode=require.
# Cada app é um database no mesmo projeto Neon (troque o nome do banco no fim).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justcore?sslmode=require"

# Armazenamento de arquivos (ver docs/integracao-sharepoint.md)
#   local      -> salva em ./storage  (dev — é o default se omitido)
#   sharepoint -> Microsoft Graph     (prod)
STORAGE_DRIVER=local

# Triagem por IA (Gemini) — lê o conteúdo do documento e propõe a classificação no GED.
# Chave gratuita do Google AI Studio (https://aistudio.google.com/apikey). Vive só aqui.
# LGPD: preferir projeto/tier que NÃO treina com os dados (dado sensível de RH).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash   # opcional (default)

# SharePoint / Graph — só quando STORAGE_DRIVER=sharepoint
# (Client/Tenant não são segredos; o SECRET vive só aqui no servidor, nunca versionado)
SP_TENANT_ID=1b1ff105-2889-46b4-b70e-5891b86a9477
SP_CLIENT_ID=684287b3-ab2c-48f0-ab44-e340b2557f5c
SP_CLIENT_SECRET=
SP_SITE=justconstrutora.sharepoint.com:/sites/PlataformaJust
# SP_ROOT="Plataforma JUST"   # pasta-base dentro da biblioteca Documentos

# E-mail (Microsoft 365 via Graph sendMail). Ver docs/integracao-email.md.
#   console -> só loga no servidor (dev — é o default se omitido)
#   graph   -> envia pelo M365 (prod) — REUSA SP_TENANT_ID/SP_CLIENT_ID/SP_CLIENT_SECRET (mesma app)
# A app precisa da permissão Mail.Send + Application Access Policy restringindo à caixa EMAIL_FROM.
EMAIL_DRIVER=console
EMAIL_FROM=naoresponda@construtorajust.com.br   # caixa COMPARTILHADA (sem licença) remetente
# EMAIL_REPLY_TO=ti@construtorajust.com.br       # opcional (responder-para padrão)
# Rate limit anti-abuso por ator (usuário/IP). Chamadas internas app->Core são isentas.
# EMAIL_RATE_MAX=60             # máx. de envios por janela (default 60)
# EMAIL_RATE_WINDOW_MS=60000    # janela em ms (default 60s)
