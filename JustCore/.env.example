# JustCore — variáveis de ambiente (copie para .env e preencha)

# Banco SQLite (Prisma)
DATABASE_URL="file:./prisma/dev.db"

# Armazenamento de arquivos (ver docs/integracao-sharepoint.md)
#   local      -> salva em ./storage  (dev — é o default se omitido)
#   sharepoint -> Microsoft Graph     (prod)
STORAGE_DRIVER=local

# SharePoint / Graph — só quando STORAGE_DRIVER=sharepoint
# (Client/Tenant não são segredos; o SECRET vive só aqui no servidor, nunca versionado)
SP_TENANT_ID=1b1ff105-2889-46b4-b70e-5891b86a9477
SP_CLIENT_ID=684287b3-ab2c-48f0-ab44-e340b2557f5c
SP_CLIENT_SECRET=
SP_SITE=justconstrutora.sharepoint.com:/sites/PlataformaJust
# SP_ROOT="Plataforma JUST"   # pasta-base dentro da biblioteca Documentos
