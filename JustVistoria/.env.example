# JustVistoria — variáveis de ambiente
PORT=4800

# Banco PostgreSQL (Prisma). Use o Neon (free tier persistente).
# Connection string POOLED do Neon (host com "-pooler") + sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justvistoria?sslmode=require"

# Cadastros-mestre (unidade/cliente/obra/colaborador) e GED vêm do JustCore.
CORE_URL=http://127.0.0.1:4100

# Token de serviço p/ chamadas app->Core (mesma string do INTERNAL_TOKEN do Core).
INTERNAL_TOKEN=

# Enforcement de auth (true em produção; vazio/false em dev local).
# AUTH_ENFORCE=true
# JWT_SECRET=  # mesmo segredo do Core (valida o token do usuário)
