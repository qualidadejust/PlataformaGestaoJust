# JustTrain — variáveis de ambiente

# Banco PostgreSQL (Prisma). Use o Neon (free tier persistente).
# Connection string POOLED do Neon (host com "-pooler") + sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justtrain?sslmode=require"

# Cadastros-mestre e templates de biometria vêm do JustCore.
CORE_URL="http://127.0.0.1:4100"
# Serviço de match SourceAFIS (.NET) — roda no totem Windows local (LAN).
BIOMETRIA_URL="http://127.0.0.1:4002"
# Limiar de aceitação do match (SourceAFIS ~40 ≈ FMR 0,01%).
MATCH_THRESHOLD=40
