# JustEleva — variáveis de ambiente

# Banco PostgreSQL (Prisma). Use o Neon (free tier persistente).
# Connection string POOLED do Neon (host com "-pooler") + sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justeleva?sslmode=require"

# Cadastros-mestre (colaboradores/obras) vêm do JustCore (script sync:core).
CORE_URL="http://127.0.0.1:4100"

# GEMINI_API_KEY: usado em recursos de IA do app (se habilitados).
GEMINI_API_KEY="MY_GEMINI_API_KEY"
