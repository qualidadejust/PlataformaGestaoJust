# JustAtestados — variáveis de ambiente
PORT=4700

# Banco PostgreSQL (Prisma). Use o Neon (free tier persistente).
# Connection string POOLED do Neon (host com "-pooler") + sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justatestados?sslmode=require"

# Cadastros-mestre (colaborador/obra/cargo) e o GED vêm do JustCore.
CORE_URL=http://127.0.0.1:4100
# Token de serviço p/ chamadas servidor→servidor (mesmo valor do Core/gateway).
INTERNAL_TOKEN=

# Auth (mesmos valores do Core/gateway). AUTH_ENFORCE=true liga as permissões do módulo.
JWT_SECRET=
AUTH_ENFORCE=false
