# Gateway — variáveis de ambiente (no Render, configure no serviço just-gateway).
# O gateway repassa cada DATABASE_URL_* para o app correspondente; as demais vars são
# herdadas por todos os processos-filhos (só quem usa lê).

# Banco por app (connection string POOLED do Neon, sslmode=require).
DATABASE_URL_CORE="postgresql://USER:PASS@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justcore?sslmode=require"
DATABASE_URL_ELEVA="postgresql://USER:PASS@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justeleva?sslmode=require"
DATABASE_URL_SECURITY="postgresql://USER:PASS@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justsecurity?sslmode=require"
DATABASE_URL_TRAIN="postgresql://USER:PASS@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justtrain?sslmode=require"
DATABASE_URL_FROTA="postgresql://USER:PASS@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justfrota?sslmode=require"

# Armazenamento de arquivos (Core) — SharePoint via Microsoft Graph.
STORAGE_DRIVER=sharepoint
SP_TENANT_ID=
SP_CLIENT_ID=
SP_CLIENT_SECRET=
SP_SITE=justconstrutora.sharepoint.com:/sites/PlataformaJust

# Biometria (.NET SourceAFIS) — roda no totem Windows local; aponte para o endereço
# acessível pelo container (ou deixe sem, se o match só ocorre no totem). Ver Fase 4.
BIOMETRIA_URL=
MATCH_THRESHOLD=40

# JustGate (WhatsApp Meta Cloud API) — só se for usar o webhook.
# WA_TOKEN=
# WA_VERIFY_TOKEN=
# WA_PHONE_NUMBER_ID=
