# JustFrota — variáveis de ambiente
PORT=4300

# Banco PostgreSQL (Prisma). Use o Neon (free tier persistente).
# Connection string POOLED do Neon (host com "-pooler") + sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.sa-east-1.aws.neon.tech/justfrota?sslmode=require"

# Cadastros-mestre (veículo/motorista/obra) vêm do JustCore.
CORE_URL=http://127.0.0.1:4100
