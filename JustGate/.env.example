# JustGate — variáveis de ambiente (copie para .env e preencha)

PORT=4200
CORE_URL=http://127.0.0.1:4100

# WhatsApp Cloud API (Meta) — do app de desenvolvedor (https://developers.facebook.com)
WA_API_VERSION=v21.0
WA_PHONE_NUMBER_ID=        # "ID do número de telefone" do número de teste da Meta
WA_TOKEN=                  # token de acesso (temporário 24h em dev; permanente via System User)
WA_VERIFY_TOKEN=just-gate-verify   # você escolhe; tem que bater com o configurado no webhook da Meta
